# ─────────────────────────────────────────────────────────────────────────────
# b2b-dashboard environment — NAMES ONLY. Never commit real values.
# Copy to `.env.local` and fill in. Only NEXT_PUBLIC_* are exposed to the browser
# and NONE of them may be a secret (no service-role key, ever).
# ─────────────────────────────────────────────────────────────────────────────

# Supabase — AUTH ONLY (login, session, MFA). The anon (publishable) key is safe
# to expose; it is NOT a service-role key. This app makes NO Supabase data calls.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLISHABLE-KEY

# GraphQL API (apps/api in moodscale-platform). The single data surface.
# Leave blank (or set NEXT_PUBLIC_USE_MOCK=true) to run mock-first against local
# fixtures before the backend exists.
NEXT_PUBLIC_GRAPHQL_URL=https://api.moodscale.example/graphql

# Mock mode — when "true" (or GRAPHQL_URL unset) the GraphQL client returns local
# fixtures instead of hitting the network. Lets the UI build/run before Supabase
# and apps/api are wired. Swap to live by setting the URL and this to "false".
NEXT_PUBLIC_USE_MOCK=true
